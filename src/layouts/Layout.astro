---
import "../styles/global.css";
import MetaTags from "../components/MetaTags.astro";
import Background from "../components/Background.astro";
import InkFilter from "../components/InkFilter.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import Reveal from "../components/Reveal.astro";

interface Props {
  title?: string;
  description?: string;
  frontmatter?: {
    title?: string;
    description?: string;
    shape?: string;
    bodyClass?: string;
    lang?: string;
  };
}

const props = Astro.props;
const title =
  props.frontmatter?.title ?? props.title ?? "CoAssembly Design co-op";
const description =
  props.frontmatter?.description ??
  props.description ??
  "Taiwan's first design studio founded on cooperative principles.";
const shape = props.frontmatter?.shape ?? "asterisk";
const bodyClass = props.frontmatter?.bodyClass ?? "";
const mainLang = props.frontmatter?.lang;
---

<!doctype html>
<html lang="en">
  <head>
    <MetaTags title={title} description={description} />
  </head>
  <body class={bodyClass} data-shape={shape}>
    <Background />
    <InkFilter />
    <Nav />
    <main lang={mainLang}>
      <slot />
      <div class="divider" aria-hidden="true"></div>
    </main>
    <Footer />
    <script>
      import { inject } from "@vercel/analytics";
      inject();
    </script>
    <Reveal />
  </body>
</html>
